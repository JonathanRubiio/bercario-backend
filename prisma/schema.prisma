datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  password     String
  name         String
  role         String           @default("mayorista")
  profile      BusinessProfile?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model BusinessProfile {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String   @unique
  name         String
  tagline      String
  description  String   @db.Text
  phone        String
  email        String
  address      String
  banner       String
  logo         String
  slug         String   @unique
  products     Json     // Array of Product
  testimonials Json     // Array of Testimonial
  faqs         Json     // Array of Faq
  gallery      Json     // Array of string
  sections     Json     // Array of LandingSection
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
